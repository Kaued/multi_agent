# Modelos de linguagem
LLM_MODEL_DEFAULT=ollama:qwen3:8b
LLM_BASE_URL=http://SEU_IP_LOCAL:11434
LLM_API_KEY=ollama
LLM_TEMPERATURE=0.7
LLM_CONTEXT_WINDOW=32768
LLM_RESPONSE_TOKEN_RESERVE=4096

# Modelo opcional por agente; use o mesmo formato de LLM_MODEL_DEFAULT
ROOT_AGENT_MODEL=ollama:qwen3:8b
POSTGRES_AGENT_MODEL=ollama:qwen3:8b
SEARCH_AGENT_MODEL=ollama:qwen3:8b
WEATHER_AGENT_MODEL=ollama:qwen3:8b
VECTOR_DB_AGENT_MODEL=ollama:qwen3:8b

# Embeddings e base vetorial
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL_DEFAULT=qwen3-embedding:4b
EMBEDDING_BASE_URL=http://SEU_IP_LOCAL:11434
# Necessária quando EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=replace-with-your-openai-api-key
DATA_SET_PATH=app/data/python_faq_dataset.csv
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=python_faq
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# APIs externas: substitua os marcadores, nunca versione chaves reais
OPENWEATHER_API_KEY=replace-with-your-openweather-api-key
TAVILY_API_KEY=replace-with-your-tavily-api-key

# PostgreSQL
POSTGRES_DB=agent_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:change-this-password@localhost:5432/agent_db

# Persistência do LangGraph
LANGGRAPH_CHECKPOINT_DB_URI=postgresql://postgres:change-this-password@localhost:5432/agent_db
LANGGRAPH_CHECKPOINT_POOL_MIN_SIZE=1
LANGGRAPH_CHECKPOINT_POOL_MAX_SIZE=10
LANGGRAPH_THREAD_ID=default-conversation

# API Flask e interface Angular
API_HOST=127.0.0.1
API_PORT=5000
UI_PORT=4200
